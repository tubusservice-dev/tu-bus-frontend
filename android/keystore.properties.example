# ─────────────────────────────────────────────────────────────────────
# Release signing (Play upload key) — TEMPLATE
# ─────────────────────────────────────────────────────────────────────
# COPY this file to `keystore.properties` (same folder) and fill in your
# real values. `keystore.properties` and `*.jks` are gitignored — NEVER
# commit them. Back up the .jks + passwords in a secure vault; with Play
# App Signing the upload key is recoverable via Google, but treat it as a
# critical secret anyway.
#
# storeFile: path to the keystore RELATIVE TO the android/ folder (this
# file's folder). Use an absolute path if it lives elsewhere.
storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
