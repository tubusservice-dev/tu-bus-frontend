<component name="InspectionProjectProfileManager">
  <profile version="1.0">
    <option name="myName" value="Project Default" />

    <!--
      ================================================================
      Spelling
      ================================================================
      Disabled project-wide. The app's user-facing copy is 100% in
      Spanish (Venezuelan dialect) and the IDE's English dictionary
      flags every Spanish word as a typo (~50 false positives per
      template). Real typos in TypeScript / class / variable names
      are still caught by the TypeScript compiler and Angular
      template type-checker. Spanish copy typos are caught visually
      during QA and by the product team's review.

      Curated brand/domain terms remain in
      .idea/dictionaries/project.xml in case Spelling is re-enabled
      later — that file documents the project vocabulary.
    -->
    <inspection_tool class="SpellCheckingInspection" enabled="false" level="TYPO" enabled_by_default="false">
      <option name="processCode" value="true" />
      <option name="processLiterals" value="true" />
      <option name="processComments" value="true" />
    </inspection_tool>

    <!--
      ================================================================
      HTML
      ================================================================
      PWA / Apple / Microsoft / OpenGraph / Twitter Card meta tags
      use vendor-prefixed names that WebStorm's HTML schema doesn't
      ship by default. Silencing "unknown attribute / unknown tag /
      unknown target" prevents ~30 false positives on valid PWA +
      social markup AND on relative paths to assets WebStorm cannot
      resolve through Angular's `public/` virtual root.

      We KEEP HtmlRequiredAltAttribute on so missing alt text on
      <img> tags still surfaces — that's an accessibility regression
      we don't want to lose.
    -->
    <inspection_tool class="HtmlUnknownAttribute" enabled="false" level="WARNING" enabled_by_default="false" />
    <inspection_tool class="HtmlUnknownTarget"    enabled="false" level="WARNING" enabled_by_default="false" />
    <inspection_tool class="HtmlUnknownTag"       enabled="false" level="WARNING" enabled_by_default="false" />
    <inspection_tool class="HtmlRequiredAltAttribute" enabled="true" level="WARNING" enabled_by_default="true" />

    <!--
      ================================================================
      TypeScript / JavaScript imports
      ================================================================
      The codebase uses relative imports throughout (no `paths`
      mapping in tsconfig.json). WebStorm's "Long import" suggestion
      generates ~25 noise warnings on every component that imports
      from sibling features. Silencing it accepts the project-wide
      convention. If we later add path aliases (@core, @shared) to
      tsconfig.json, this can be flipped back on.
    -->
    <inspection_tool class="LongImport" enabled="false" level="WARNING" enabled_by_default="false" />
    <inspection_tool class="JSPotentiallyInvalidUsageOfClassThis" enabled="true" level="WARNING" enabled_by_default="true" />
  </profile>
</component>
